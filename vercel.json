{
  "redirects": [
    {
      "source": "/commercial-cleaning-danbury-ct",
      "destination": "https://prefmaint.com/",
      "permanent": true
    },
    {
      "source": "/commercial-cleaning-danbury-ct/",
      "destination": "https://prefmaint.com/",
      "permanent": true
    },
    {
      "source": "/commercial-cleaning-danbury-ct/:path*",
      "destination": "https://prefmaint.com/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.prefmaint.com"
        }
      ],
      "destination": "https://prefmaint.com/:path*",
      "permanent": true
    }
  ]
}
